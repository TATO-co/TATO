APP_VARIANT=development
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_DEV_BYPASS_EMAIL=dev@example.com
EXPO_PUBLIC_DEV_BYPASS_PASSWORD=change-me
EXPO_PUBLIC_LIVE_AGENT_SERVICE_URL=https://your-cloud-run-service.a.run.app
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_posthog_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project-id

# Optional Sentry build-time config for release uploads (not public Expo env)
# SENTRY_AUTH_TOKEN=your-sentry-auth-token
# SENTRY_ORG=your-sentry-organization
# SENTRY_PROJECT=your-sentry-project

# Supabase Edge Function secrets (set in Supabase Dashboard, not client env)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# GEMINI_API_KEY=your-gemini-api-key
# STRIPE_SECRET_KEY=sk_live_or_test
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_REFRESH_URL=https://app.tato.example/payments
# STRIPE_CONNECT_RETURN_URL=https://app.tato.example/payments
# STRIPE_CHECKOUT_SUCCESS_URL=https://app.tato.example/payments?checkout=success&session_id={CHECKOUT_SESSION_ID}
# STRIPE_CHECKOUT_CANCEL_URL=https://app.tato.example/payments?checkout=cancel
# SUPABASE_ACCESS_TOKEN=for-ci-deploy
# SUPABASE_PROJECT_REF=your-project-ref
